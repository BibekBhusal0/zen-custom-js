{
  "name": "Zen Browser UserScripts",
  "description": "Personal customization userscripts and css files for enhanceing browsing experience in Zen Browser",
  "scripts": {
    "build": "bun build.js",
    "build:browsebot": "TARGET=browsebot bun build.js",
    "build:palette": "TARGET=palette bun build.js",
    "build:reopen": "TARGET=reopen bun build.js",
    "build:sidebar": "TARGET=sidebar bun build.js",
    "build:select": "TARGET=select bun build.js",
    "build:search": "TARGET=search bun build.js",
    "dev": "bun build.js --watch",
    "dev:browsebot": "TARGET=browsebot bun build.js --watch",
    "dev:palette": "TARGET=palette bun build.js --watch",
    "dev:reopen": "TARGET=reopen bun build.js --watch",
    "dev:sidebar": "TARGET=sidebar bun build.js --watch",
    "dev:select": "TARGET=select bun build.js --watch",
    "dev:search": "TARGET=search bun build.js --watch",
    "combine-preferences": "bun .github/scripts/combine-preferences.js",
    "update-theme": "bun .github/scripts/update-theme.js",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "author": "Bibek Bhusal",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/cerebras": "^3.0.12",
    "@ai-sdk/google": "^4.0.18",
    "@ai-sdk/openai": "^4.0.16",
    "@ai-sdk/openai-compatible": "^3.0.12",
    "ai": "^7.0.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "bun": "^1.3.14",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
